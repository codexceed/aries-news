# Copy to .env and fill in. Never commit the real .env.

# --- Database (matches docker-compose.yml defaults) ---
DATABASE_URL=postgresql+asyncpg://aries:aries@localhost:5432/aries

# --- News API (https://gnews.io — free tier: 100 requests/day) ---
GNEWS_API_KEY=your-gnews-key
GNEWS_BASE_URL=https://gnews.io/api/v4

# --- OpenAI ---
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4.1-nano

# --- App behavior ---
# Max concurrent OpenAI analysis jobs (semaphore bound).
INSIGHTS_MAX_CONCURRENCY=4
# Seconds a job may stay "running" before the startup reaper re-queues it.
INSIGHTS_STALE_AFTER_SECONDS=120
# Seconds to cache a news query response (protects the 100 req/day quota).
NEWS_CACHE_TTL_SECONDS=300

LOG_LEVEL=INFO
